# Authentication
AUTH_MODE=bearer                    # none | bearer
AUTH_BEARER_TOKEN=your-secret-token

# Default account — SMTP (sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_START_TLS=true
SMTP_USE_TLS=false
SMTP_VERIFY_SSL=true
SMTP_FROM_ADDRESS=you@gmail.com
SMTP_FROM_NAME=MCP Mail Agent
SMTP_SAVE_TO_SENT=true

# Default account — IMAP (reading)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=you@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=true
IMAP_VERIFY_SSL=true

# Additional accounts (JSON string, from K8s Secret)
# ACCOUNTS_JSON={"work":{"smtp":{"host":"smtp.office365.com","port":587,"username":"you@company.com","password":"...","start_tls":true},"imap":{"host":"outlook.office365.com","port":993,"username":"you@company.com","password":"...","use_ssl":true},"from_address":"you@company.com","from_name":"Your Name","rate_limit_per_minute":30,"max_recipients":50,"allowed_domains":["company.com"]}}
ACCOUNTS_JSON=

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RATE_LIMIT_PER_MINUTE=30
APP_MAX_RECIPIENTS=50
APP_MAX_BODY_LENGTH=20000
APP_ALLOWED_DOMAINS=
